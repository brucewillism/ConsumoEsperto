# Copie para a raiz: `cp docker/env.docker.example .env`
# Documentação: docker/README.md · docs/WHATSAPP_EVOLUTION.md

# PostgreSQL (host 5439 → container 5432)
POSTGRES_USER=consumo
POSTGRES_PASSWORD=mude_para_um_segredo_longo
POSTGRES_DB=consumo_db

# Spring Boot
JWT_SECRET=mude_para_pelo_menos_256_bits_de_entropia

# Google OAuth2 (tipo "Aplicação Web" na Google Cloud Console — mesmo Client ID que no Angular)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# Evolution API — mesma chave no Spring e AUTHENTICATION_API_KEY (defina UM dos nomes abaixo):
EVOLUTION_API_KEY=mude_esta_chave_partilhada
# Evolução “legado” (sem _KEY) também serve: EVOLUTION_APIKEY=mesmo_valor
EVOLUTION_INSTANCE=ConsumoEsperto
# URL que o BACKEND usa na rede Docker (não é a URL pública):
EVOLUTION_URL=http://evolution_api:8585
# URL pública da Evolution (SERVER_URL no contentor) — QR e webhooks. Ex.: https://dominio:8585
EVOLUTION_SERVER_URL=https://consumoesperto.brucew07.com.br:8585
# Alias aceite pelo compose: EVOLUTION_PUBLISH=mesmo_valor_que_EVOLUTION_SERVER_URL
# Legado (alguns scripts): EVOLUTION_PUBLIC_URL=http://127.0.0.1:8585
# Imagem por defeito no compose: evoapicloud/evolution-api:latest
# Privacidade WhatsApp (recomendado para notificações no telemóvel):
# EVOLUTION_ALWAYS_ONLINE=false
# EVOLUTION_READ_MESSAGES=false
# EVOLUTION_PRIVACY_SET_UNAVAILABLE=true
# EVOLUTION_SESSION_STICKY=true

# Webhook interno Evolution → Spring (rede Docker; porta do backend = 8087)
# WEBHOOK_GLOBAL_URL=http://backend:8087/api/public/evolution/webhook

# CORS / OAuth — todas as ORIGENS onde o Angular abre (scheme + host + porta se não for :80/:443-padrão)
APP_FRONTEND_BASE_URL=http://localhost:8181
# Exemplo HTTPS atrás do Apache na 8443: inclua "...:8443" na lista ou use padrões ampliados no application.properties do backend.
CORS_ALLOWED_PATTERNS=http://localhost:8181,http://127.0.0.1:8181,https://consumoesperto.brucew07.com.br,https://consumoesperto.brucew07.com.br:8443

# Portas expostas no host (referência — já definidas no docker-compose.yml)
# Postgres 5439 | Backend 8087 | Frontend 8181 | Evolution 8585 | Ollama 11999

# IA — chaves cloud opcionais; sem nenhuma, o backend usa Ollama (contentor ollama na rede Docker).
# GROQ_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
