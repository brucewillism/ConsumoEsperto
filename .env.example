# Copie para .env e ajuste (nunca commite o .env com segredos reais).

DATABASE_URL=jdbc:postgresql://localhost:5432/consumoesperto
DATABASE_USERNAME=consumo
DATABASE_PASSWORD=mude_isto

JWT_SECRET=mude_para_uma_string_longa_e_aleatoria

# Evolution API em Node (tools/evolution-api ou EVOLUTION_DIR).
EVOLUTION_URL=http://localhost:18080
# Evolution API — mesma chave que AUTHENTICATION_API_KEY / API_TOKEN na Evolution (Compose usa típicamente esta):
EVOLUTION_API_KEY=mude_isto
# Alternativa também lida pelo Spring: EVOLUTION_APIKEY=mesmo_valor
EVOLUTION_INSTANCE=ConsumoEsperto
# Produção Compose: URL pública da Evolution (SERVER_URL no contentor evolution_api) — NÃO use a URL do frontend.
# Sem isto /instance/connect devolve {"count":0} e o QR não aparece na app.
# Ex.: https://consumoesperto.brucew07.com.br:8585  ou  https://consumoesperto.brucew07.com.br/evolution
EVOLUTION_SERVER_URL=https://consumoesperto.brucew07.com.br:8585
# Opcional: painel Manager (defeito: EVOLUTION_SERVER_URL + /manager)
# EVOLUTION_MANAGER_URL=

# Docker (evoapicloud/evolution-api): Redis segundo env oficial — CACHE_REDIS_URI para o serviço `redis`; não usar só REDIS_HOST/REDIS_ENABLED.
# EVOLUTION_CACHE_REDIS_ENABLED=true
# Seeds no compose: redis://redis:6379/0

# Postgres: password com @ : / ? # deve ir percent-encoded em DATABASE_CONNECTION_URI se montar esse URI á mão.

# Opcional: GET /instance/connect — tentativas e pausa (ms) antes de desistir do QR pela REST (defeitos: 6 e 4000).
# EVOLUTION_PAIRING_CONNECT_RETRIES=6
# EVOLUTION_PAIRING_CONNECT_PAUSE_MS=4000

# Opcional: fallback de IA no servidor quando o utilizador não tem chaves em UsuarioAiConfig.
# Ordem fixa: Groq → OpenAI → Claude → Gemini → DeepSeek → Ollama (Token Suppressor antes de cada chamada).
GROQ_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
# CLAUDE_BASE_URL=https://api.anthropic.com
# CLAUDE_MODEL=claude-3-5-haiku-20241022
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# Docker Compose: URL interna do contentor Ollama (nao use localhost:11999 no backend).
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2

# AI Token Suppressor (opcional) — reduz tokens antes das chamadas de IA
# TOKEN_SUPPRESSOR_ENABLED=true
# TOKEN_SUPPRESSOR_URL=http://191.252.210.60:8100
# TOKEN_SUPPRESSOR_API_KEY=sua_chave_do_painel_admin
# TOKEN_SUPPRESSOR_STRATEGY=balanced
# TOKEN_SUPPRESSOR_MIN_CHARS=1200

# URL pública do backend (OAuth2 / callbacks); em produção use https://seu-dominio
PUBLIC_APP_URL=http://127.0.0.1:18081

# true = criar Utilizador ao receber WhatsApp de número novo (multi-tenant).
WHATSAPP_AUTO_PROVISION_USER=true
# true = cada utilizador com instância Evolution dedicada ce-u{id} (recomendado; evita «não é possível ligar outro dispositivo» entre contas).
EVOLUTION_DEDICATED_INSTANCE_PER_USER=true
# Opcional: URL que a Evolution chama por instância (Compose: http://backend:8087/api/public/evolution/webhook).
# EVOLUTION_WEBHOOK_BACKEND_URL=
# Modo fantasma WhatsApp (recomendado): não força online nem marca mensagens como lidas (preserva notificações no telemóvel)
# EVOLUTION_ALWAYS_ONLINE=false
# EVOLUTION_READ_MESSAGES=false
# EVOLUTION_READ_STATUS=false
# EVOLUTION_SYNC_FULL_HISTORY=false
# EVOLUTION_PRIVACY_RESTART_AFTER_APPLY=true
# EVOLUTION_PRIVACY_SET_UNAVAILABLE=true

# OAuth2 Web (ConsumoEsperto) — mesmo ID que em frontend/src/environments/environment.ts
GOOGLE_CLIENT_ID=593452038228-xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret_da_consola
# Google Cloud Console → Credenciais → Cliente OAuth "Aplicativo da Web":
#   Origens JavaScript autorizadas (exatamente o URL do browser, sem barra final):
#     http://localhost:14200
#     https://consumoesperto.brucew07.com.br
#   URIs de redirecionamento (se usar fluxo server-side): http://localhost:18081/api/integracoes/google-calendar/oauth2/callback
