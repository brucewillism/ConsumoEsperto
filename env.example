# =============================================================================
# ARQUIVO DE EXEMPLO DE VARIÁVEIS DE AMBIENTE - CONSUMO ESPERTO
# =============================================================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env (renomeie para .env)
# 2. Preencha os valores com suas credenciais reais
# 3. NUNCA commite o arquivo .env no Git!
#
# =============================================================================

# =============================================================================
# CONFIGURAÇÕES DO BANCO DE DADOS
# =============================================================================
DATABASE_URL=jdbc:postgresql://localhost:5432/consumoesperto
DATABASE_USERNAME=seu_usuario
DATABASE_PASSWORD=sua_senha_segura

# =============================================================================
# CONFIGURAÇÕES JWT (SEGURANÇA)
# =============================================================================
# IMPORTANTE: Use uma chave secreta forte de pelo menos 256 bits!
# Gere uma chave segura: openssl rand -base64 32
JWT_SECRET=sua_chave_secreta_jwt_super_segura_de_pelo_menos_256_bits
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# =============================================================================
# CONFIGURAÇÕES GOOGLE OAUTH2
# =============================================================================
GOOGLE_CLIENT_ID=seu_google_client_id
GOOGLE_CLIENT_SECRET=seu_google_client_secret

# =============================================================================
# CONFIGURAÇÕES MERCADO PAGO
# =============================================================================
MERCADOPAGO_CLIENT_ID=seu_mercadopago_client_id
MERCADOPAGO_CLIENT_SECRET=seu_mercadopago_client_secret
MERCADOPAGO_USER_ID=seu_mercadopago_user_id

# =============================================================================
# CONFIGURAÇÕES NUBANK
# =============================================================================
NUBANK_CLIENT_ID=seu_nubank_client_id
NUBANK_CLIENT_SECRET=seu_nubank_client_secret

# =============================================================================
# CONFIGURAÇÕES ITAÚ
# =============================================================================
ITAU_CLIENT_ID=seu_itau_client_id
ITAU_CLIENT_SECRET=seu_itau_client_secret

# =============================================================================
# CONFIGURAÇÕES INTER
# =============================================================================
INTER_CLIENT_ID=seu_inter_client_id
INTER_CLIENT_SECRET=seu_inter_client_secret

# =============================================================================
# CONFIGURAÇÕES NGROK
# =============================================================================
# URL pública do ngrok (ou domínio em produção)
NGROK_URL=https://seu-dominio.ngrok-free.app
NGROK_AUTHTOKEN=seu_ngrok_authtoken

# =============================================================================
# CONFIGURAÇÕES JAVA (para IDEs)
# =============================================================================
# Execute configurar-java-home.bat ou configurar-java-home.ps1 para gerar automaticamente
JAVA_HOME=./tools/java/ms-17.0.15

